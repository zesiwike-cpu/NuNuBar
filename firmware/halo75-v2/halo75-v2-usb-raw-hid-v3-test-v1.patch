+static void agent_light_show(void)
+{
+    static uint8_t previous_link_mode = LINK_USB;
+    agent_light_pixel_t frame[SIDE_LED_COUNT];
+    agent_light_command_t command;
+
+    if (dev_info.link_mode != previous_link_mode) {
+        if (previous_link_mode == LINK_USB) {
+            agent_light_usb_status = 0;
+            agent_light_usb_effect = AGENT_LIGHT_EFFECT_FACTORY;
+        }
+        previous_link_mode = dev_info.link_mode;
+    }
+
+    // Caps Lock (0x02) remains owned by the factory host LED indicator layer.
+    command.status = dev_info.link_mode == LINK_USB ? agent_light_usb_status : (dev_info.rf_led & 0x05);
+    if (dev_info.link_mode == LINK_USB) {
+        command.red = agent_light_usb_red;
+        command.green = agent_light_usb_green;
+        command.blue = agent_light_usb_blue;
+        command.effect = agent_light_usb_effect;
+    } else {
+        agent_light_default_color(command.status, &command);
+        command.effect = agent_light_default_effect(command.status);
+    }
+    if (command.effect == AGENT_LIGHT_EFFECT_FACTORY) return;
+
+    if (!agent_light_render(
+        command.effect,
+        command.red,
+        command.green,
+        command.blue,
+        timer_read32(),
+        frame
+    )) return;
+
+    for (uint8_t i = 0; i < SIDE_LED_COUNT; i++) {
+        rgb_matrix_set_color(
+            side_led_index_tab[i],
+            frame[i].r,
+            frame[i].g,
+            frame[i].b
+        );
+    }
+}
