diff --git a/keyboards/nuphy/halo75_v2/ansi/agent_light_protocol.h b/keyboards/nuphy/halo75_v2/ansi/agent_light_protocol.h
new file mode 100644
index 0000000..a852275
--- /dev/null
+++ b/keyboards/nuphy/halo75_v2/ansi/agent_light_protocol.h
@@ -0,0 +1,109 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+#pragma once
+
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+
+#define AGENT_LIGHT_USB_REPORT_SIZE 32
+#define AGENT_LIGHT_EFFECT_SOLID 0x00
+#define AGENT_LIGHT_EFFECT_BREATHE 0x01
+#define AGENT_LIGHT_EFFECT_BLINK 0x02
+#define AGENT_LIGHT_EFFECT_WAVE 0x03
+#define AGENT_LIGHT_EFFECT_FACTORY 0xFF
+
+typedef struct {
+    uint8_t status;
+    uint8_t red;
+    uint8_t green;
+    uint8_t blue;
+    uint8_t effect;
+} agent_light_command_t;
+
+static inline bool agent_light_status_is_valid(uint8_t status)
+{
+    return status == 0x00 || status == 0x01 || status == 0x04 || status == 0x05;
+}
+
+static inline void agent_light_default_color(uint8_t status, agent_light_command_t *command)
+{
+    command->red = 0;
+    command->green = 0;
+    command->blue = 0;
+
+    switch (status) {
+        case 0x01:
+            command->red = 255;
+            command->green = 80;
+            break;
+        case 0x04:
+            command->red = 255;
+            break;
+        case 0x05:
+            command->green = 255;
+            break;
+    }
+}
+
+static inline uint8_t agent_light_default_effect(uint8_t status)
+{
+    switch (status) {
+        case 0x01: return AGENT_LIGHT_EFFECT_WAVE;
+        case 0x04: return AGENT_LIGHT_EFFECT_BLINK;
+        case 0x05: return AGENT_LIGHT_EFFECT_SOLID;
+        default: return AGENT_LIGHT_EFFECT_FACTORY;
+    }
+}
+
+static inline bool agent_light_effect_is_valid(uint8_t effect)
+{
+    return effect == AGENT_LIGHT_EFFECT_SOLID
+        || effect == AGENT_LIGHT_EFFECT_BREATHE
+        || effect == AGENT_LIGHT_EFFECT_BLINK;
+}
+
+static inline bool agent_light_decode_usb_report(
+    const uint8_t *data,
+    uint8_t length,
+    agent_light_command_t *command
+)
+{
+    if (data == NULL || command == NULL || length != AGENT_LIGHT_USB_REPORT_SIZE) return false;
+    if (data[0] != 0x4E || data[1] != 0x42 || data[2] != 0x41 || data[3] != 0x52) return false;
+    if (data[5] != 0x01) return false;
+    if (!agent_light_status_is_valid(data[6])) return false;
+
+    uint8_t checksum = 0;
+    if (data[4] == 0x01) {
+        for (uint8_t i = 0; i < 7; i++) checksum ^= data[i];
+        if (checksum != data[7]) return false;
+        command->status = data[6];
+        agent_light_default_color(command->status, command);
+        command->effect = agent_light_default_effect(command->status);
+        return true;
+    }
+
+    if (data[4] == 0x02) {
+        for (uint8_t i = 0; i < 10; i++) checksum ^= data[i];
+        if (checksum != data[10]) return false;
+        command->status = data[6];
+        command->red = data[7];
+        command->green = data[8];
+        command->blue = data[9];
+        command->effect = agent_light_default_effect(command->status);
+        return true;
+    }
+
+    if (data[4] == 0x03) {
+        for (uint8_t i = 0; i < 11; i++) checksum ^= data[i];
+        if (checksum != data[11] || !agent_light_effect_is_valid(data[10])) return false;
+        command->status = data[6];
+        command->red = data[7];
+        command->green = data[8];
+        command->blue = data[9];
+        command->effect = data[10];
+        return true;
+    }
+
+    return false;
+}
diff --git a/keyboards/nuphy/halo75_v2/ansi/tests/agent_light_protocol_test.c b/keyboards/nuphy/halo75_v2/ansi/tests/agent_light_protocol_test.c
new file mode 100644
index 0000000..e9cd9cc
--- /dev/null
+++ b/keyboards/nuphy/halo75_v2/ansi/tests/agent_light_protocol_test.c
@@ -0,0 +1,66 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+#include <assert.h>
+#include <stdint.h>
+#include <string.h>
+
+#include "../agent_light_protocol.h"
+
+static void set_checksum(uint8_t report[AGENT_LIGHT_USB_REPORT_SIZE], uint8_t end, uint8_t target)
+{
+    uint8_t value = 0;
+    for (uint8_t i = 0; i < end; i++) value ^= report[i];
+    report[target] = value;
+}
+
+int main(void)
+{
+    uint8_t report[AGENT_LIGHT_USB_REPORT_SIZE] = {
+        0x4E, 0x42, 0x41, 0x52, 0x03, 0x01, 0x01, 0x12, 0x34, 0x56,
+        AGENT_LIGHT_EFFECT_BREATHE,
+    };
+    agent_light_command_t command;
+    set_checksum(report, 11, 11);
+
+    assert(agent_light_decode_usb_report(report, sizeof(report), &command));
+    assert(command.status == 0x01);
+    assert(command.red == 0x12);
+    assert(command.green == 0x34);
+    assert(command.blue == 0x56);
+    assert(command.effect == AGENT_LIGHT_EFFECT_BREATHE);
+
+    report[10] = AGENT_LIGHT_EFFECT_BLINK;
+    set_checksum(report, 11, 11);
+    assert(agent_light_decode_usb_report(report, sizeof(report), &command));
+    assert(command.effect == AGENT_LIGHT_EFFECT_BLINK);
+
+    report[10] = AGENT_LIGHT_EFFECT_SOLID;
+    set_checksum(report, 11, 11);
+    assert(agent_light_decode_usb_report(report, sizeof(report), &command));
+    assert(command.effect == AGENT_LIGHT_EFFECT_SOLID);
+
+    report[10] = AGENT_LIGHT_EFFECT_WAVE;
+    set_checksum(report, 11, 11);
+    assert(!agent_light_decode_usb_report(report, sizeof(report), &command));
+
+    memset(report, 0, sizeof(report));
+    report[0] = 0x4E;
+    report[1] = 0x42;
+    report[2] = 0x41;
+    report[3] = 0x52;
+    report[4] = 0x01;
+    report[5] = 0x01;
+    report[6] = 0x05;
+    set_checksum(report, 7, 7);
+
+    assert(agent_light_decode_usb_report(report, sizeof(report), &command));
+    assert(command.status == 0x05);
+    assert(command.red == 0);
+    assert(command.green == 255);
+    assert(command.blue == 0);
+    assert(command.effect == AGENT_LIGHT_EFFECT_SOLID);
+
+    report[7] ^= 0x01;
+    assert(!agent_light_decode_usb_report(report, sizeof(report), &command));
+
+    return 0;
+}
